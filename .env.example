# Django Settings
DEBUG=False
SECRET_KEY=your-secret-key-here-change-this-to-random-string
ALLOWED_HOSTS=backend.tmfouzy.sg,localhost,127.0.0.1

# Database Configuration (if using MySQL on cPanel)
# Uncomment and configure if using MySQL instead of SQLite
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=tmfouzys_umrah
# DB_USER=tmfouzys_admin
# DB_PASSWORD=your-database-password
# DB_HOST=localhost
# DB_PORT=3306

# Email Configuration
EMAIL_HOST=mail.tmfouzy.sg
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_HOST_USER=tmfttotp@tmfouzy.sg
EMAIL_HOST_PASSWORD=your-actual-email-password-here

# Google Gemini AI Configuration
# Get your free API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Live Audio Streaming Configuration
# Agora.io - Sign up at: https://www.agora.io/
AGORA_APP_ID=your-agora-app-id-here
AGORA_APP_CERTIFICATE=your-agora-app-certificate-here

# Firebase Cloud Messaging (Push Notifications)
# Get from: https://console.firebase.google.com/ > Project Settings > Cloud Messaging
FCM_SERVER_KEY=your-firebase-server-key-here

# CORS Settings (Frontend domains that can access backend)
CORS_ALLOWED_ORIGINS=https://tmfouzy.sg,https://www.tmfouzy.sg

# Static and Media Files (for production)
STATIC_ROOT=/home/tmfouzys/public_html/backend/static
MEDIA_ROOT=/home/tmfouzys/public_html/backend/media

